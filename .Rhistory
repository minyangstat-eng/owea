library(kernlab)
library(MultiRNG)
library(hetGP)
library(GPcluster)
library(twingp)
Borehole = function(xx){
mini = c(0.05,100,63070,990,63.1,700,1120,9855)
maxi = c(0.15,50000,115600,1110,116,820,1680,12045)
#mini = c(0.05,100,63070,990,63.1,700,1120,1500)
#maxi = c(0.15,50000,115600,1110,116,820,1680,15000)
rw <- mini[1] + xx[1]*(maxi[1] - mini[1])
r  <- mini[2] + xx[2]*(maxi[2] - mini[2])
Tu <- mini[3] + xx[3]*(maxi[3] - mini[3])
Hu <- mini[4] + xx[4]*(maxi[4] - mini[4])
Tl <- mini[5] + xx[5]*(maxi[5] - mini[5])
Hl <- mini[6] + xx[6]*(maxi[6] - mini[6])
L  <- mini[7] + xx[7]*(maxi[7] - mini[7])
Kw <- mini[8] + xx[8]*(maxi[8] - mini[8])
frac1 <- 2 * pi * Tu * (Hu-Hl)
frac2a <- 2*L*Tu / (log(r/rw)*rw^2*Kw)
frac2b <- Tu / Tl
frac2 <- log(r/rw) * (1+frac2a+frac2b)
y <- frac1 / frac2
return(y)
}
pho = 0
d = 8
size_train = 1000
SNR = 5
np = 1000
cov_matrix = (matrix(pho, d, d) + t(matrix(pho, d, d)))/2
diag(cov_matrix) = 1
full_data = draw.d.variate.uniform(no.row=size_train, d=d, cov.mat=cov_matrix)
train_X = full_data
Y_signal = apply(as.matrix(train_X), 1, Borehole)
sigma = sqrt(var(Y_signal)/SNR)
Y_noise = rnorm(size_train, mean=0, sd=sigma)
train_Y = Y_signal + Y_noise
train_X
x <- y <- seq(-3, 3, length = 50)
z <- outer(x, y, function(x, y) x^2 + y^2)
persp(x, y, z,
theta = 30, phi = 30,
col = "lightblue",
expand = 0.5)
plot3d(x, y, z, type = "s", size = 0.7)
install.packages("rgl")
library(rgl)
plot3d(x, y, z, type = "s", size = 0.7)
x
train_X[,1]
plot3d(train_X[,1], train_X[,2], train_Y, type = "s", size = 1)
plot3d(train_X[,3], train_X[,7], train_Y, type = "s", size = 1)
plot(train_X[,3], train_Y,pch = 16)
png( width = 1200, height = 800)  # height in pixels
plot(train_X[,3], train_Y,pch = 16)
data(mcycle)
attach(mcycle)
plot(times,accel,pch = 16)
mat=c(train_X,train_Y)
mat
df <- as.data.frame(mat)
df
df <- as.data.frame(train_X)
df
plot(V1,V2,pch = 16)
attach(df)
plot(V1,V2,pch = 16)
