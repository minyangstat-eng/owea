set.seed(1)
n <- 10000
p <- 5
K <- 3
true_beta  <- matrix(1:10,  nrow = p, ncol = K - 1)  # p x (K-1)
true_theta <- matrix(1:15,  nrow = p, ncol = K)      # p x K
true_Sigma <- c(0.5, 1, 1.5)
# Design matrices (p x n) with intercept row
X <- rbind(
rep(1, n),
matrix(runif(n*(p-1), -1, 1), nrow = p - 1, ncol = n)
)
X_beta <- X_theta <- X
# Gate probabilities via stable softmax (no internal helpers)
softmax_cols <- function(S) {
S  <- sweep(S, 2, apply(S, 2, max))   # numerical stabilisation
EX <- exp(S)
sweep(EX, 2, colSums(EX), "/")
}
scores  <- rbind(t(true_beta) %*% X_beta, 0)  # K x n (last class = baseline 0)
P       <- softmax_cols(scores)
cluster <- sapply(seq_len(ncol(P)), function(i) sample.int(K, 1, prob = P[, i]))
# Generate response from the selected expert
Y <- sapply(1:n, function(i)
as.numeric(t(X_theta[, i]) %*% true_theta[, cluster[i]] +
rnorm(1, 0, true_Sigma[cluster[i]]))
)
# Fit MoE
start=proc.time()
fit <- fit_MoE(X_beta, X_theta, Y, c = K, rep = 10)
runtime=proc.time()-start
runtime
